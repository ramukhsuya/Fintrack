# Required application settings
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
SESSION_SECRET=replace-with-a-long-random-secret

# Google sign-in
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# FlowFin AI Assistant (keep this server-side; do not put it in client/.env)
GEMINI_API_KEY=your-google-ai-studio-api-key
# Optional. The code defaults to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# Optional email reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
MAIL_FROM=FlowFin <no-reply@example.com>
EMAIL_REMINDER_CRON=0 8 * * *
EMAIL_REMINDER_TIMEZONE=Asia/Kolkata
