# Existing application variables
MONGODB_URI=
SESSION_SECRET=

# SMTP provider details (for Gmail, use an App Password rather than your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-or-app-password
MAIL_FROM="FlowFin <your-email@example.com>"

# Daily 8:00 AM in India. Change for development/testing if needed.
EMAIL_REMINDER_CRON="0 8 * * *"
EMAIL_REMINDER_TIMEZONE=Asia/Kolkata
